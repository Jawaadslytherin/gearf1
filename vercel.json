{
  "routes": [
    {
      "src": "/sitemap.xml",
      "dest": "https://gearf1backend-production.up.railway.app/api/sitemap"
    },
    { "handle": "filesystem" },
    {
      "src": "/robots.txt",
      "dest": "/robots.txt"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
